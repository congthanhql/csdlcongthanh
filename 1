  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    :root{
      --bg:#f4f6fb;
      --text:#333;
      --muted:#666;
      --card:#ffffff;
      --shadow:0 4px 12px rgba(0,0,0,0.08);
      --shadow-hover:0 12px 25px rgba(0,0,0,0.15);
      --primary1:#667eea;
      --primary2:#764ba2;
      --vip:#ff9800;
    }

    *{box-sizing:border-box;}

    body {
      font-family: 'Segoe UI', sans-serif;
      margin: 0;
      background: var(--bg);
      color: var(--text);
    }

    header {
      background: linear-gradient(135deg, var(--primary1), var(--primary2));
      color: white;
      text-align: center;
      padding: 50px 20px;
    }

    header h1 {
      margin: 0;
      font-size: 36px;
    }

    header p {
      margin-top: 10px;
      font-size: 18px;
      opacity: 0.9;
    }

    .container {
      max-width: 1100px;
      margin: 30px auto;
      padding: 20px;
    }

    .section-title {
      font-size: 24px;
      margin: 40px 0 20px;
      font-weight: 700;
      color: var(--primary2);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    .card {
      background: var(--card);
      border-radius: 16px;
      padding: 25px;
      text-align: center;
      text-decoration: none;
      color: var(--text);
      box-shadow: var(--shadow);
      transition: 0.25s ease;
      display:block;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-hover);
    }

    .icon {
      font-size: 40px;
      margin-bottom: 12px;
    }

    .title {
      font-weight: bold;
      font-size: 18px;
      margin-bottom: 8px;
    }

    .desc {
      font-size: 14px;
      color: var(--muted);
    }

    .vip {
      border: 2px solid var(--vip);
      background: linear-gradient(135deg, #fff7e6, #fff);
    }

    footer {
      text-align: center;
      padding: 25px;
      color: #888;
      font-size: 14px;
      background: #f0f0f0;
      margin-top: 40px;
    }

    @media (max-width:600px){
      header h1{font-size:28px;}
      header p{font-size:16px;}
    }
  </style>
</head>

