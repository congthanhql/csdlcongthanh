/* RENDER */

function renderList(data=database){

let html="";

data.forEach(item=>{

html+=`

<div class="item" onclick="showDetail('${item.uid}')">

<div class="icon">📄</div>

<div class="info">
UID: ${item.uid} | Tham Chiếu: ${item.code}
</div>

</div>

`;

});

document.getElementById("list").innerHTML=html;

}

/* SEARCH */

function handleEnter(event){

if(event.key==="Enter"){
searchData();
}

}

function searchData(){

let key=document
.getElementById("searchInput")
.value
.trim()
.toLowerCase();

const notFound=document.getElementById("notFound");

if(key===""){

renderList();
notFound.style.display="none";
return;

}

let result=database.filter(item=>

item.uid.toLowerCase().includes(key)

||

item.code.toLowerCase().includes(key)

);

if(result.length){

renderList(result);
notFound.style.display="none";

}else{

document.getElementById("list").innerHTML="";
notFound.style.display="block";

}

}

/* DETAIL */

function showDetail(uid){

let data=database.find(x=>x.uid===uid);

document.getElementById("detailContent").innerHTML=`

<b>Mã UID:</b> ${data.uid}<br>

<b>Mã Tham Chiếu:</b> ${data.code}<br>

<b>Tên PNG:</b> ${data.png}<br>

<b>Ngày Xuất Bản:</b> ${data.date}<br>

<b>Khách Hàng:</b> ${data.kh}<br>

<a
href="${data.link}"
target="_blank"
class="link-btn">
MỞ HỒ SƠ
</a>

`;

document.getElementById("detailModal")
.style.display="flex";

}

function closeDetail(){

document.getElementById("detailModal")
.style.display="none";

}

/* LOGOUT */

function logout(){

location.reload();

}

/* CLICK OUTSIDE */

window.onclick=function(e){

let detailModal=
document.getElementById("detailModal");

if(e.target===detailModal){

closeDetail();

}

};

