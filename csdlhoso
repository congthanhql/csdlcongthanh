<!-- LOGIN -->

<div id="loginPage">

<div class="login-box">

<h2>Đăng Nhập Hệ Thống</h2>

<input
id="user"
placeholder="Tên đăng nhập">

<input
id="pass"
type="password"
placeholder="Mật khẩu">

<button
class="btn"
onclick="login()">
Đăng Nhập </button>

</div>

</div>

<!-- APP -->

<div id="app">

<div class="header">

<button class="logout" onclick="logout()">
Đăng Xuất
</button>

<div class="title">
📂 Danh Sách Hồ Sơ
</div>

<div class="search">

<input
id="searchInput"
placeholder="🔍 Nhập UID hoặc Mã tham chiếu..."
onkeypress="handleEnter(event)">

<button onclick="searchData()">
Tra Cứu
</button>

</div>

</div>

<div class="not-found" id="notFound">
❌ Không tìm thấy Hồ Sơ
</div>

<div class="list" id="list"></div>

</div>

<!-- DETAIL MODAL -->

<div class="modal" id="detailModal">

<div class="modal-content">

<button
class="close-x"
onclick="closeDetail()">
✕ </button>

<h3>Thông Tin Hồ Sơ</h3>

<div
class="detail"
id="detailContent">
</div>

</div>

</div>

